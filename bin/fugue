#!/usr/bin/env bash
#
# fugue — run an AI coding agent in a no-trace, sandboxed session.
#
# A fugue state is dissociative amnesia: you act, then retain no memory of it.
# That is what this does to a coding agent — it runs, does the work, and leaves
# nothing behind: no transcript, no telemetry, no phone-home, no lingering
# credentials or caches. The guarantee comes from the environment, not from the
# agent behaving.
#
# Two backends provide the sandbox:
#   docker  (default)  full isolation in a --rm container: tmpfs $HOME, an
#                      nftables egress allowlist (--strict), telemetry kill-env.
#   native  (macOS)    no container: the host's agent runs under sandbox-exec
#                      (Seatbelt) with writes denied outside the project and
#                      reads of secrets (SSH keys, cloud creds) denied by the
#                      kernel. Closest to running on your real tree, safely.
#
# Usage:
#   fugue <agent> [args...]                 # claude | codex | gemini | ...
#   fugue claude "refactor src/"
#   fugue --backend native codex "explain this stack trace"
#   fugue --ephemeral-workspace gemini "try a risky migration"
#   fugue --ro-dir ~/.cache/go-build aider "..."
#   fugue shellenv [bash|zsh|fish]          # shell wrappers; eval in your rc
#
# Flags:
#   --backend <docker|native>  execution backend (default: docker; env FUGUE_BACKEND)
#   --strict                   docker: hard egress allowlist (default; needs NET_ADMIN)
#   --no-net-isolation         docker: env-only mode, no firewall (weaker, portable)
#   --ephemeral-workspace      run against a throwaway copy of the cwd; host tree untouched
#   --add-dir <path>           also expose <path> read-write inside the sandbox (repeatable)
#   --ro-dir <path>            also expose <path> read-only inside the sandbox (repeatable)
#   --share-home               native: keep the real $HOME (for agents that need host login)
#   --keep-on-error            do not auto-teardown if the agent exits non-zero (debug)
#   --image <ref>              docker: override the image (default: ghcr.io/dotbrains/fugue)
#   -h, --help                 this help
#
# Subcommands:
#   shellenv [shell]           print shell functions that route each agent through
#                              fugue (run `command <agent>` to bypass).
#
set -euo pipefail

FUGUE_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
IMAGE="${FUGUE_IMAGE:-ghcr.io/dotbrains/fugue:latest}"
BACKEND="${FUGUE_BACKEND:-docker}"
STRICT=1
EPHEMERAL_WS=0
KEEP_ON_ERROR=0
SHARE_HOME=0
NATIVE_TMP="" # set by run_native; cleaned by its EXIT trap
declare -a ADD_DIRS_RW=()
declare -a ADD_DIRS_RO=()

die() {
  printf 'fugue: %s\n' "$*" >&2
  exit 2
}

usage() {
  sed -n '2,52p' "${BASH_SOURCE[0]}" | sed 's/^# \{0,1\}//'
  exit 0
}

known_agents() {
  local p
  for p in "$FUGUE_ROOT"/profiles/*.env; do
    [[ -e "$p" ]] || continue
    p="${p##*/}"
    printf '%s ' "${p%.env}"
  done
}

# --- shellenv subcommand -----------------------------------------------------
# Emit shell functions so `claude ...` transparently becomes `fugue claude ...`.
# `command claude` still runs the unsandboxed agent (the shell builtin skips the
# function), matching the documented bypass.
# This function deliberately prints literal shell ($argv, $(...)) for the user's
# rc file, so single-quoted expansions are intentional.
# shellcheck disable=SC2016
emit_shellenv() {
  local shell="${1:-posix}" agent self
  self="${BASH_SOURCE[0]}"
  case "$shell" in
    fish)
      printf '# fugue shell wrappers — add to ~/.config/fish/config.fish:\n'
      printf '#   %s shellenv fish | source\n' "$self"
      for agent in $(known_agents); do
        printf 'function %s; command %s %s $argv; end\n' "$agent" "$self" "$agent"
      done
      ;;
    bash | zsh | posix)
      printf '# fugue shell wrappers — add to your ~/.%src:\n' "${shell/posix/bash}"
      printf '#   eval "$(%s shellenv %s)"\n' "$self" "${shell/posix/bash}"
      for agent in $(known_agents); do
        printf '%s() { command %s %s "$@"; }\n' "$agent" "$self" "$agent"
      done
      ;;
    *) die "unknown shell '$shell' for shellenv (try: bash | zsh | fish)" ;;
  esac
}

if [[ "${1:-}" == "shellenv" ]]; then
  shift
  emit_shellenv "${1:-posix}"
  exit 0
fi

# --- parse flags (stop at the agent name) -----------------------------------
while [[ $# -gt 0 ]]; do
  case "$1" in
    --backend)
      BACKEND="${2:?--backend needs a value}"
      shift 2
      ;;
    --strict)
      STRICT=1
      shift
      ;;
    --no-net-isolation)
      STRICT=0
      shift
      ;;
    --ephemeral-workspace)
      EPHEMERAL_WS=1
      shift
      ;;
    --add-dir)
      ADD_DIRS_RW+=("${2:?--add-dir needs a path}")
      shift 2
      ;;
    --ro-dir)
      ADD_DIRS_RO+=("${2:?--ro-dir needs a path}")
      shift 2
      ;;
    --share-home)
      SHARE_HOME=1
      shift
      ;;
    --keep-on-error)
      KEEP_ON_ERROR=1
      shift
      ;;
    --image)
      IMAGE="${2:?--image needs a value}"
      shift 2
      ;;
    -h | --help) usage ;;
    --)
      shift
      break
      ;;
    -*) die "unknown flag: $1" ;;
    *) break ;;
  esac
done

case "$BACKEND" in
  docker | native) ;;
  *) die "unknown backend '$BACKEND' (use: docker | native)" ;;
esac

AGENT="${1:-}"
[[ -n "$AGENT" ]] || die "no agent given. try: fugue claude \"...\"  (see --help)"
shift || true

PROFILE="$FUGUE_ROOT/profiles/$AGENT.env"
[[ -f "$PROFILE" ]] || die "unknown agent '$AGENT' (no profile at $PROFILE). known: $(known_agents)"

# --- load the agent profile --------------------------------------------------
# Profiles export: AGENT_CMD, API_KEY_VARS, API_HOSTS, TELEMETRY_ENV (array),
# and BACKENDS (space-separated list of supported backends).
# shellcheck source=/dev/null
source "$PROFILE"

# Backend support is declared per profile; default to docker if a profile
# predates the field.
BACKENDS="${BACKENDS:-docker}"
case " $BACKENDS " in
  *" $BACKEND "*) ;;
  *) die "agent '$AGENT' does not support the '$BACKEND' backend (supports: $BACKENDS). try --backend ${BACKENDS%% *}" ;;
esac

# Forward exactly the credential(s) this agent needs, nothing else.
declare -a CRED_VARS=()
for var in ${API_KEY_VARS:-}; do
  [[ -n "${!var:-}" ]] && CRED_VARS+=("$var")
done

# Resolve a host path to an absolute, real path (no trailing slash surprises).
abspath() { (cd "$1" 2>/dev/null && pwd) || die "no such directory: $1"; }

# Shred the native backend's temp tree (ephemeral $HOME, workspace copy, and the
# generated profile). Invoked indirectly via `trap ... EXIT` in run_native, so
# its only call site is invisible to static analysis (flagged unused/unreachable).
# shellcheck disable=SC2329,SC2317
scrub_native() {
  local rc=$?
  [[ -n "$NATIVE_TMP" ]] || return
  if [[ "$KEEP_ON_ERROR" -eq 1 && "$rc" -ne 0 ]]; then
    printf 'fugue: agent exited %s; --keep-on-error set, leaving %s\n' "$rc" "$NATIVE_TMP" >&2
    return
  fi
  rm -rf "$NATIVE_TMP"
}

# ============================================================================
# docker backend
# ============================================================================
run_docker() {
  command -v docker >/dev/null || die "docker not found on PATH"
  [[ ${#CRED_VARS[@]} -gt 0 ]] || die "no API key in env for $AGENT (expected one of: ${API_KEY_VARS:-?})"

  # The tmpfs/mount specs below carry commas inside single values (rw,exec,...),
  # which shellcheck misreads as array-element separators (SC2054).
  # shellcheck disable=SC2054
  declare -a DOCKER_ARGS=(
    run --rm -it
    --hostname fugue
    # ephemeral $HOME — every agent writes its state/history/transcripts here
    --tmpfs /home/agent:rw,exec,uid=1001,gid=1001,mode=0700
    # no new privileges; drop the lot, add back only what egress needs
    --security-opt no-new-privileges
    --cap-drop ALL
    # kill the managed-sandbox trace surfaces if the base image carries them
    -e FUGUE=1
    -e HOME=/home/agent
    -e DISABLE_AUTOUPDATER=1
    -e DO_NOT_TRACK=1
  )

  # per-agent telemetry / analytics kill switches (from profile)
  for kv in "${TELEMETRY_ENV[@]}"; do
    DOCKER_ARGS+=(-e "$kv")
  done

  for var in "${CRED_VARS[@]}"; do
    DOCKER_ARGS+=(-e "$var")
  done

  # workspace mount
  if [[ "$EPHEMERAL_WS" -eq 1 ]]; then
    # copy-on-tmpfs: agent edits a throwaway copy, host cwd is never touched
    # shellcheck disable=SC2054  # commas live inside the tmpfs spec, not between args
    DOCKER_ARGS+=(--tmpfs /workspace:rw,exec,mode=0777 -e FUGUE_EPHEMERAL_WS=1)
  else
    DOCKER_ARGS+=(-v "$(pwd):/workspace:rw")
  fi
  DOCKER_ARGS+=(-w /workspace)

  # extra directories, mounted at their host path inside the container
  local d real
  for d in ${ADD_DIRS_RW[@]+"${ADD_DIRS_RW[@]}"}; do
    real="$(abspath "$d")"
    DOCKER_ARGS+=(-v "$real:$real:rw")
  done
  for d in ${ADD_DIRS_RO[@]+"${ADD_DIRS_RO[@]}"}; do
    real="$(abspath "$d")"
    DOCKER_ARGS+=(-v "$real:$real:ro")
  done

  # egress isolation
  if [[ "$STRICT" -eq 1 ]]; then
    DOCKER_ARGS+=(--cap-add NET_ADMIN -e "FUGUE_ALLOW_HOSTS=$API_HOSTS" -e FUGUE_STRICT=1)
  else
    DOCKER_ARGS+=(-e FUGUE_STRICT=0)
  fi
  [[ "$KEEP_ON_ERROR" -eq 1 ]] && DOCKER_ARGS+=(-e FUGUE_KEEP_ON_ERROR=1)

  printf 'fugue: %s session (docker) — strict=%s ephemeral-ws=%s — no trace will persist\n' \
    "$AGENT" "$STRICT" "$EPHEMERAL_WS" >&2

  set +e
  docker "${DOCKER_ARGS[@]}" "$IMAGE" \
    /usr/local/bin/fugue-entry "$AGENT_CMD" "" "$@"
  local rc=$?
  set -e
  return "$rc"
}

# ============================================================================
# native backend (macOS sandbox-exec / Seatbelt)
# ============================================================================
run_native() {
  [[ "$(uname -s)" == "Darwin" ]] || die "the native backend requires macOS (sandbox-exec). use --backend docker"
  command -v sandbox-exec >/dev/null || die "sandbox-exec not found (macOS only)"
  command -v "$AGENT_CMD" >/dev/null || die "native backend needs '$AGENT_CMD' installed on your host (it is not on PATH)"
  if [[ ${#CRED_VARS[@]} -eq 0 && "$SHARE_HOME" -eq 0 ]]; then
    die "no API key in env for $AGENT (expected one of: ${API_KEY_VARS:-?}); or pass --share-home to use your host login"
  fi

  local real_home="$HOME" workdir run_home tmproot profile
  tmproot="$(mktemp -d "${TMPDIR:-/tmp}/fugue.XXXXXX")"
  NATIVE_TMP="$tmproot" # visible to the EXIT trap after this function returns

  # workspace: the cwd, or a throwaway copy of it under --ephemeral-workspace
  if [[ "$EPHEMERAL_WS" -eq 1 ]]; then
    workdir="$tmproot/workspace"
    mkdir -p "$workdir"
    cp -R "$(pwd)/." "$workdir/" 2>/dev/null || true
  else
    workdir="$(pwd)"
  fi

  # $HOME: ephemeral by default (no-trace); the real home only with --share-home
  if [[ "$SHARE_HOME" -eq 1 ]]; then
    run_home="$real_home"
  else
    run_home="$tmproot/home"
    mkdir -p "$run_home"
  fi

  profile="$tmproot/fugue.sb"
  native_profile "$real_home" "$workdir" "$run_home" >"$profile"

  trap scrub_native EXIT

  printf 'fugue: %s session (native/sandbox-exec) — ephemeral-ws=%s share-home=%s — writes leashed to the project\n' \
    "$AGENT" "$EPHEMERAL_WS" "$SHARE_HOME" >&2

  # Start from a clean environment (no host secrets leak in), then add back a
  # small, safe passthrough plus the agent's own kill-env and credentials.
  local -a env_args=(
    "HOME=$run_home"
    "PATH=$PATH"
    FUGUE=1
    DISABLE_AUTOUPDATER=1
    DO_NOT_TRACK=1
  )
  local passvar
  for passvar in TERM LANG LC_ALL LC_CTYPE TMPDIR SSL_CERT_FILE SSL_CERT_DIR \
    HTTP_PROXY HTTPS_PROXY NO_PROXY; do
    [[ -n "${!passvar:-}" ]] && env_args+=("$passvar=${!passvar}")
  done
  for kv in "${TELEMETRY_ENV[@]}"; do env_args+=("$kv"); done
  for var in "${CRED_VARS[@]}"; do env_args+=("$var=${!var}"); done

  set +e
  (cd "$workdir" && env -i "${env_args[@]}" \
    sandbox-exec -f "$profile" "$AGENT_CMD" "$@")
  local rc=$?
  set -e
  return "$rc"
}

# Emit the Seatbelt (SBPL) profile. Model: allow reads broadly so toolchains
# work, but deny reads of a sensitive set; deny *writes* everywhere except the
# project, the ephemeral $HOME, temp, and any --add-dir paths. Last match wins.
native_profile() {
  local real_home="$1" workdir="$2" run_home="$3" d real
  cat <<SB
(version 1)
(allow default)

;; --- writes: deny everywhere, then re-allow the project and scratch areas ---
(deny file-write*)
(allow file-write* (subpath "$workdir"))
(allow file-write* (subpath "$run_home"))
(allow file-write* (subpath "/private/tmp"))
(allow file-write* (subpath "/private/var/tmp"))
(allow file-write* (subpath "/private/var/folders"))
(allow file-write* (subpath "/dev"))
SB
  for d in ${ADD_DIRS_RW[@]+"${ADD_DIRS_RW[@]}"}; do
    real="$(abspath "$d")"
    printf '(allow file-write* (subpath "%s"))\n' "$real"
  done

  cat <<SB

;; --- reads: deny secrets and credential stores (kernel-enforced) ---
(deny file-read* (subpath "$real_home/.ssh"))
(deny file-read* (subpath "$real_home/.aws"))
(deny file-read* (subpath "$real_home/.gnupg"))
(deny file-read* (subpath "$real_home/.config/gh"))
(deny file-read* (subpath "$real_home/.config/gcloud"))
(deny file-read* (subpath "$real_home/.kube"))
(deny file-read* (subpath "$real_home/.docker"))
(deny file-read* (subpath "$real_home/Library/Keychains"))
(deny file-read* (literal "$real_home/.netrc"))
(deny file-read* (literal "$real_home/.npmrc"))
(deny file-read* (literal "$real_home/.pypirc"))
SB

  # caller-supplied extra read denials (space-separated absolute subpaths)
  for d in ${FUGUE_DENY_READ:-}; do
    printf '(deny file-read* (subpath "%s"))\n' "$d"
  done

  # read-only extra dirs are readable by the broad allow above; nothing to add.
  for d in ${ADD_DIRS_RO[@]+"${ADD_DIRS_RO[@]}"}; do
    : "$(abspath "$d")" # validate it exists; reads already allowed
  done
}

rc=0
case "$BACKEND" in
  docker) run_docker "$@" || rc=$? ;;
  native) run_native "$@" || rc=$? ;;
esac
exit "$rc"
