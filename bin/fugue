#!/usr/bin/env bash
#
# fugue — run an AI coding agent in a no-trace, sandboxed session.
#
# A fugue state is dissociative amnesia: you act, then retain no memory of it.
# That is what this does to a coding agent — it runs, does the work, and leaves
# nothing behind: no transcript, no telemetry, no phone-home, no lingering
# credentials or caches. The guarantee comes from the environment, not from the
# agent behaving.
#
# Two backends provide the sandbox:
#   docker  (default)  full isolation in a --rm container: tmpfs $HOME, an
#                      nftables egress allowlist (--strict), telemetry kill-env.
#   native  (macOS)    no container: the host's agent runs under sandbox-exec
#                      (Seatbelt) with writes denied outside the project and
#                      reads of secrets (SSH keys, cloud creds) denied by the
#                      kernel. Closest to running on your real tree, safely.
#
# Usage:
#   fugue <agent> [args...]                 # claude | codex | gemini | ...
#   fugue claude "refactor src/"
#   fugue --backend native codex "explain this stack trace"
#   fugue --ephemeral-workspace gemini "try a risky migration"
#   fugue --ro-dir ~/.cache/go-build aider "..."
#   fugue shellenv [bash|zsh|fish]          # shell wrappers; eval in your rc
#
# Flags:
#   --backend <docker|native>  execution backend (default: docker; env FUGUE_BACKEND)
#   --strict                   docker: hard egress allowlist (default; needs NET_ADMIN)
#   --no-net-isolation         docker: env-only mode, no firewall (weaker, portable)
#   --ephemeral-workspace      run against a throwaway copy of the cwd; host tree untouched
#   --add-dir <path>           also expose <path> read-write inside the sandbox (repeatable)
#   --ro-dir <path>            also expose <path> read-only inside the sandbox (repeatable)
#   --share-home               native: keep the real $HOME (for agents that need host login)
#   --append-profile <path>    native: append a custom Seatbelt profile (repeatable)
#   --trust-workdir-config     native: load .fugue from cwd (ro-dir/add-dir/append-profile)
#   --keep-on-error            do not auto-teardown if the agent exits non-zero (debug)
#   --image <ref>              docker: override the image (default: ghcr.io/dotbrains/fugue)
#   -h, --help                 this help
#
# Subcommands:
#   shellenv [shell]           print shell functions that route each agent through
#                              fugue (run `command <agent>` to bypass).
#
set -euo pipefail

FUGUE_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
IMAGE="${FUGUE_IMAGE:-ghcr.io/dotbrains/fugue:latest}"
BACKEND="${FUGUE_BACKEND:-docker}"
STRICT=1
EPHEMERAL_WS=0
KEEP_ON_ERROR=0
SHARE_HOME=0
TRUST_WORKDIR_CONFIG=0
WORKDIR_CONFIG_PATH=""
NATIVE_TMP="" # set by run_native; cleaned by its EXIT trap
declare -a ADD_DIRS_RW=()
declare -a ADD_DIRS_RO=()
declare -a APPEND_PROFILES=()

die() {
  printf 'fugue: %s\n' "$*" >&2
  exit 2
}

usage() {
  sed -n '2,52p' "${BASH_SOURCE[0]}" | sed 's/^# \{0,1\}//'
  exit 0
}

# shellcheck source=bin/lib/fugue-shellenv
source "$FUGUE_ROOT/bin/lib/fugue-shellenv"
# shellcheck source=bin/lib/fugue-cli
source "$FUGUE_ROOT/bin/lib/fugue-cli"
# shellcheck source=bin/lib/fugue-workdir-config
source "$FUGUE_ROOT/bin/lib/fugue-workdir-config"

if [[ "${1:-}" == "shellenv" ]]; then
  shift
  emit_shellenv "${1:-posix}"
  exit 0
fi

parse_flags "$@"
shift "$PARSED_FLAG_COUNT"
load_workdir_config
load_profile "$@"
shift
collect_credentials

# Resolve a directory to its absolute, *physical* path. `pwd -P` matters on
# macOS, where /var, /tmp, /etc are symlinks to /private/... and the Seatbelt
# sandbox matches the canonical (resolved) path, not the symlinked one.
abspath() { (cd "$1" 2>/dev/null && pwd -P) || die "no such directory: $1"; }

absfile() {
  local path="$1" dir base
  [[ -f "$path" ]] || die "no such file: $path"
  [[ -r "$path" ]] || die "cannot read file: $path"
  dir="$(cd "$(dirname "$path")" 2>/dev/null && pwd -P)" || die "no such directory: $(dirname "$path")"
  base="$(basename "$path")"
  printf '%s/%s\n' "$dir" "$base"
}

# shellcheck source=bin/lib/fugue-docker
source "$FUGUE_ROOT/bin/lib/fugue-docker"
# shellcheck source=bin/lib/fugue-native
source "$FUGUE_ROOT/bin/lib/fugue-native"

rc=0
case "$BACKEND" in
  docker) run_docker "$@" || rc=$? ;;
  native) run_native "$@" || rc=$? ;;
esac
exit "$rc"
