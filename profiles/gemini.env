# fugue profile: Gemini CLI (Google)
#
# shellcheck shell=bash
# These are consumed by the script that sources this file, not here.
# shellcheck disable=SC2034

AGENT_CMD="gemini"
# Gemini CLI accepts either; fugue forwards whichever is set in the host env.
API_KEY_VARS="GEMINI_API_KEY GOOGLE_API_KEY"

API_HOSTS="generativelanguage.googleapis.com"

TELEMETRY_ENV=(
  "GEMINI_TELEMETRY_ENABLED=false"
  "GEMINI_CLI_DISABLE_TELEMETRY=1"
  "DISABLE_AUTOUPDATER=1"
  "DO_NOT_TRACK=1"
)
