# fugue profile: Pi coding agent (@earendil-works/pi-coding-agent)
#
# Multi-provider; forwards whichever provider key is set. Native only.
#
# shellcheck shell=bash
# These are consumed by the script that sources this file, not here.
# shellcheck disable=SC2034

AGENT_CMD="pi"
API_KEY_VARS="ANTHROPIC_API_KEY OPENAI_API_KEY"
API_HOSTS="api.anthropic.com api.openai.com pi.dev"
BACKENDS="native"

TELEMETRY_ENV=(
  "PI_TELEMETRY=0"
  "PI_SKIP_VERSION_CHECK=1"
  "DO_NOT_TRACK=1"
)
