# fugue profile: Claude Code (Anthropic)
#
# Sourced by bin/fugue. Defines how to launch the agent, which credential to
# forward, which hosts egress is allowed to reach, and the telemetry kill-env.
#
# shellcheck shell=bash
# These are consumed by the script that sources this file, not here.
# shellcheck disable=SC2034

AGENT_CMD="claude"
API_KEY_VARS="ANTHROPIC_API_KEY"

# Backends this agent runs under: docker (baked into the image) and native
# (macOS sandbox-exec, using the host's installed CLI).
BACKENDS="docker native"

# Egress allowlist (TCP 443). Keep this minimal — every host here is a hole.
API_HOSTS="api.anthropic.com"

# Telemetry / analytics / error-reporting / autoupdate kill switches.
TELEMETRY_ENV=(
  "CLAUDE_CODE_ENABLE_TELEMETRY=0"
  "DISABLE_TELEMETRY=1"
  "DISABLE_ERROR_REPORTING=1"
  "DISABLE_BUG_COMMAND=1"
  "DISABLE_AUTOUPDATER=1"
  "DISABLE_NON_ESSENTIAL_MODEL_CALLS=1"
)
