# fugue profile: Codex (OpenAI)

AGENT_CMD="codex"
API_KEY_VARS="OPENAI_API_KEY"

# Codex talks to the OpenAI API; the CLI also checks for updates on npm.
# We allow only the API host — autoupdate is killed via env below.
API_HOSTS="api.openai.com"

TELEMETRY_ENV=(
  "OPENAI_TELEMETRY=0"
  "CODEX_DISABLE_TELEMETRY=1"
  "DISABLE_AUTOUPDATER=1"
  "DO_NOT_TRACK=1"
)
