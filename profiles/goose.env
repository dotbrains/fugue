# fugue profile: Goose (block/goose)
#
# Rust binary; multi-provider via per-provider API keys. Native only.
#
# shellcheck shell=bash
# These are consumed by the script that sources this file, not here.
# shellcheck disable=SC2034

AGENT_CMD="goose"
API_KEY_VARS="OPENAI_API_KEY ANTHROPIC_API_KEY GOOGLE_API_KEY"
API_HOSTS="api.openai.com api.anthropic.com generativelanguage.googleapis.com"
BACKENDS="native"

TELEMETRY_ENV=(
  "GOOSE_TELEMETRY_ENABLED=false"
  "OTEL_SDK_DISABLED=true"
  "DO_NOT_TRACK=1"
)
