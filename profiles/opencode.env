# fugue profile: OpenCode (sst/opencode)
#
# Multi-provider; forwards whichever provider key is set in the host env.
# Native backend only (run the host's `opencode`); to use the docker backend,
# add `opencode-ai` to package.json and set BACKENDS="docker native".
#
# shellcheck shell=bash
# These are consumed by the script that sources this file, not here.
# shellcheck disable=SC2034

AGENT_CMD="opencode"
API_KEY_VARS="ANTHROPIC_API_KEY OPENAI_API_KEY OPENROUTER_API_KEY"
API_HOSTS="api.anthropic.com api.openai.com openrouter.ai opencode.ai"
BACKENDS="native"

TELEMETRY_ENV=(
  "OPENCODE_DISABLE_AUTOUPDATE=1"
  "DO_NOT_TRACK=1"
)
