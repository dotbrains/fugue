# fugue profile: Cline CLI (cline/cline)
#
# Multi-provider; CLINE_API_KEY uses the hosted Cline backend, or forward a
# provider key directly. Native only.
#
# shellcheck shell=bash
# These are consumed by the script that sources this file, not here.
# shellcheck disable=SC2034

AGENT_CMD="cline"
API_KEY_VARS="CLINE_API_KEY ANTHROPIC_API_KEY OPENAI_API_KEY"
API_HOSTS="api.cline.bot api.anthropic.com api.openai.com"
BACKENDS="native"

# No documented telemetry env var (it is a settings toggle); best-effort.
TELEMETRY_ENV=(
  "DO_NOT_TRACK=1"
  "DISABLE_AUTOUPDATER=1"
)
