# fugue profile: Droid (Factory AI)
#
# Account agent; FACTORY_API_KEY (fk-...) is the non-interactive credential.
# Native only.
#
# shellcheck shell=bash
# These are consumed by the script that sources this file, not here.
# shellcheck disable=SC2034

AGENT_CMD="droid"
API_KEY_VARS="FACTORY_API_KEY"
API_HOSTS="app.factory.ai api.factory.ai"
BACKENDS="native"

# No documented telemetry/autoupdate kill var; portable best-effort switches.
TELEMETRY_ENV=(
  "DO_NOT_TRACK=1"
  "DISABLE_AUTOUPDATER=1"
)
