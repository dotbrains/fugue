# fugue profile: Cursor Agent (cursor-agent)
#
# Installed binary (not npm). API key auth via CURSOR_API_KEY. Native only.
#
# shellcheck shell=bash
# These are consumed by the script that sources this file, not here.
# shellcheck disable=SC2034

AGENT_CMD="cursor-agent"
API_KEY_VARS="CURSOR_API_KEY"
API_HOSTS="api.cursor.com api2.cursor.com auth.cursor.com"
BACKENDS="native"

# No documented telemetry/autoupdate kill var; portable best-effort switches.
TELEMETRY_ENV=(
  "DO_NOT_TRACK=1"
  "DISABLE_AUTOUPDATER=1"
)
