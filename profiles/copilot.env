# fugue profile: GitHub Copilot CLI
#
# Authenticates against a GitHub account/subscription. A PAT with the Copilot
# permission can be supplied via one of the token vars below. Native only.
#
# shellcheck shell=bash
# These are consumed by the script that sources this file, not here.
# shellcheck disable=SC2034

AGENT_CMD="copilot"
API_KEY_VARS="COPILOT_GITHUB_TOKEN GH_TOKEN GITHUB_TOKEN"
API_HOSTS="api.githubcopilot.com api.github.com"
BACKENDS="native"

# No documented telemetry-only kill var (COPILOT_OFFLINE disables ALL network,
# which would break the agent); fall back to the broadly-honored switches.
TELEMETRY_ENV=(
  "DO_NOT_TRACK=1"
  "DISABLE_AUTOUPDATER=1"
)
