# fugue profile: Kilo Code CLI (@kilocode/cli)
#
# Uses the Kilo gateway by default (KILO_API_KEY), or BYO provider keys. Native
# only.
#
# shellcheck shell=bash
# These are consumed by the script that sources this file, not here.
# shellcheck disable=SC2034

AGENT_CMD="kilo"
API_KEY_VARS="KILO_API_KEY ANTHROPIC_API_KEY OPENAI_API_KEY"
API_HOSTS="api.kilo.ai app.kilo.ai api.anthropic.com api.openai.com"
BACKENDS="native"

# Telemetry is an opt-in config setting (no env var); best-effort switches.
TELEMETRY_ENV=(
  "DO_NOT_TRACK=1"
  "DISABLE_AUTOUPDATER=1"
)
