# fugue profile: Amp (Sourcegraph)
#
# Hosted backend handles inference; AMP_API_KEY is the non-interactive token.
# Native backend only (run the host's `amp`).
#
# shellcheck shell=bash
# These are consumed by the script that sources this file, not here.
# shellcheck disable=SC2034

AGENT_CMD="amp"
API_KEY_VARS="AMP_API_KEY"
API_HOSTS="ampcode.com"
BACKENDS="native"

TELEMETRY_ENV=(
  "AMP_SKIP_UPDATE_CHECK=1"
  "DO_NOT_TRACK=1"
)
