# fugue profile: Aider
#
# Python tool (pip), so docker support would need a Python layer — native only.
# Multi-provider via LiteLLM; forwards whichever key is set.
#
# shellcheck shell=bash
# These are consumed by the script that sources this file, not here.
# shellcheck disable=SC2034

AGENT_CMD="aider"
API_KEY_VARS="ANTHROPIC_API_KEY OPENAI_API_KEY"
API_HOSTS="api.anthropic.com api.openai.com"
BACKENDS="native"

# Aider's analytics opt-out is a flag (--no-analytics / --analytics-disable),
# not an env var; DO_NOT_TRACK is the portable best-effort switch.
TELEMETRY_ENV=(
  "DO_NOT_TRACK=1"
)
