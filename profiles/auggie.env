# fugue profile: Auggie (Augment Code CLI)
#
# Account-login agent: the non-interactive credential is a session JSON in
# AUGMENT_SESSION_AUTH (from `auggie token print`). Native only.
#
# shellcheck shell=bash
# These are consumed by the script that sources this file, not here.
# shellcheck disable=SC2034

AGENT_CMD="auggie"
API_KEY_VARS="AUGMENT_SESSION_AUTH"
# Egress is tenant-specific (<tenant>.api.augmentcode.com); widen per tenant.
API_HOSTS="api.augmentcode.com"
BACKENDS="native"

TELEMETRY_ENV=(
  "AUGMENT_DISABLE_AUTO_UPDATE=1"
  "DO_NOT_TRACK=1"
)
